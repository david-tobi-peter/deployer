# ── Deployer Configuration ──
# Copy this file to .env and adjust values as needed.
# All values shown below are the defaults used by the application.

# Server
NODE_ENV=production
PORT=3000

# Storage (SQLite DB + deployment logs)
STORAGE_DIR=/app/storage

# BuildKit daemon address
BUILDKIT_HOST=tcp://buildkit:1234

# Port range for deployed containers
DEPLOYMENT_PORT_START=4000
